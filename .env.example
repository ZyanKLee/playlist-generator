# ── Deezer application credentials ──────────────────────────────────────────
# Register at https://developers.deezer.com/ to obtain these values.
# The redirect URI must match the one registered in your Deezer app settings.

DEEZER_APP_ID=
DEEZER_SECRET=
DEEZER_REDIRECT_URI=http://localhost:8080/callback

# ── Database ─────────────────────────────────────────────────────────────────
# Defaults to SQLite in output/cache.db.
# Uncomment and adjust for PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/playlist_generator

# ── Cache TTL (hours) ────────────────────────────────────────────────────────
CACHE_TTL_HOURS=24
